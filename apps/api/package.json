{
  "name": "@fasnexi/api",
  "version": "0.1.0",
  "description": "Fasnexi API - Next.js 14 Backend",
  "main": "index.ts",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "type-check": "tsc --noEmit",
    "test": "jest --passWithNoTests",
    "test:e2e": "playwright test",
    "db:migrate": "prisma migrate dev",
