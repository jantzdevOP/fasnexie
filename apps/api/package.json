{
  "name": "@fasnexi/api",
  "version": "0.1.0",
  "description": "Fasnexi API - Next.js 14 Backend",
  "main": "index.ts",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:e2e": "playwright test",
    "db:migrate": "prisma migrate dev",
    "db:seed": "node scripts/seed.ts",
    "db:studio": "prisma studio",
    "clean": "rm -rf .next dist node_modules"
  },
  "dependencies": {
    "next": "^16.2.9",
    "react": "19.2.7",
    "react-dom": "18.2.0",
    "@prisma/client": "^5.0.0",
    "better-auth": "^1.0.0",
    "anthropic": "^0.10.0",
    "stripe": "^13.0.0",
    "zod": "^3.22.0",
    "redis": "^6.0.0",
    "bullmq": "^4.11.0"
  },
  "devDependencies": {
    "@repo/eslint-config": "*",
    "@repo/tsconfig": "*",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/jest": "^29.5.0",
    "typescript": "^5.2.0",
    "eslint": "^8.50.0",
    "prettier": "^3.0.0",
    "jest": "^30.4.2",
    "@testing-library/react": "^14.0.0",
    "@playwright/test": "^1.40.0",
    "prisma": "^7.8.0",
    "ts-node": "^10.9.0"
  }
