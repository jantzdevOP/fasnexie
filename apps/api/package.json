    "better-auth": "^1.0.0",
    "bullmq": "^4.11.0",
    "next": "^16.2.9",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "redis": "^6.0.0",
    "stripe": "^22.2.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@jest/types": "^29.6.3",
    "@playwright/test": "^1.40.0",
    "@repo/eslint-config": "*",
    "@repo/tsconfig": "*",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "eslint": "^8.57.1",
    "jest": "^29.7.0",
    "prettier": "^3.0.0",
    "prisma": "^7.8.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.0",
    "typescript": "^5.2.0"
  }
